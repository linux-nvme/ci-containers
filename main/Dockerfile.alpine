FROM alpine:latest

ARG TARGETPLATFORM
ENV LANG=en_US.utf8
ENV TZ=Europe/Berlin

RUN apk update && \
    apk add musl-locales tzdata && \
    apk add \
    clang \
    gcc \
    git \
    meson \
    bash \
    linux-headers \
    musl-dev \
    perl \
    json-c-dev \
    openssl-dev \
    keyutils-dev \
    dbus-dev \
    liburing-dev \
    file \
    wget \
    clang-analyzer \
    python3 \
    python3-dev \
    py3-pip \
    py3-virtualenv \
    && apk cache clean && \
    rm -rf /var/cache/apk/* /tmp/* /var/tmp/*


WORKDIR /build